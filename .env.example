# Ideagram PWA - Environment Configuration
# Copy this file to .env and fill in the required values.

# API Configuration
# The base URL for the backend API. Used for proxying in vite.config.ts during development.
# Default: https://ideagram.ideamakr.com/backend/api/v1/
VITE_API_BASE_URL=https://ideagram.ideamakr.com/backend/api/v1/

# Feature Flags
# Set to 'true' to enable experimental video uploads
VITE_ENABLE_VIDEO_UPLOAD=false

# Deployment Configuration
# Port for the development server (default: 5173)
PORT=5173
