# Ideagram PWA - Environment Configuration

# Features Toggle
VITE_ENABLE_VIDEO_UPLOAD=false

# API Configuration
# The production API base URL is proxied via vite.config.ts for development.
# If you need to point to a local backend, you can specify it here (future-proofing).
# VITE_API_BASE_URL=https://ideagram.ideamakr.com/backend/api/v1/
